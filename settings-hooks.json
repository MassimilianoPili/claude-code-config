{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/block-dangerous-commands.sh"
          },
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/git-push-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/protect-sensitive-files.sh"
          },
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/scan-secrets-in-content.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/auto-shellcheck.sh"
          },
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/auto-gofmt.sh"
          },
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/auto-stage.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/command-audit-log.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/session-context-loader.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/compact-context-preserver.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/config-audit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/stop-reminder.sh"
          },
          {
            "type": "command",
            "command": "/data/massimiliano/.claude/hooks/readme-update-reminder.sh"
          }
        ]
      }
    ]
  }
}
