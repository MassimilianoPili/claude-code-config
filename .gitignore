# API key config
.claude.json

# Local-only permission overrides (sensitive grants: ssh_exec, gaia access, dangerous-mode)
settings.local.json

# Conversations (2.2GB, on HDD RAID1)
projects

# Plugin runtime (regenerated from marketplace)
plugins/cache/
plugins/marketplaces/
plugins/*.tmp

# Override global gitignore (data/ excluded globally for Docker volumes)
!plugins/data/

# Misc
*.log
audit/
.env
*.key
*.pem
